<launch>
    <arg name="world_frame" default="parking_start_map" />
    <node name="space_detect_and_tf_to_map" pkg="perception" type="space_detect_and_tf_to_map.py" output="screen">
        <param name="model_path" value="$(find perception)/weights/yolo_obb_best.pt"/>
        <param name="world_frame" value="$(arg world_frame)"/>
    </node>
</launch>